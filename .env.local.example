# Local engine env. Copy to .env.local and fill in.
#   cp .env.local.example .env.local
#   chmod 600 .env.local
# .env.local is gitignored.

# --- Hyperliquid ---
# In paper mode (config/strategy.yaml: paper_mode: true) these are not used to
# sign anything — HLClient.paper_mode short-circuits before SDK init. Dummy
# values are fine.
# In live mode, HL_API_SECRET_KEY must be the private key of the wallet you
# want to trade with. Treat it like a password; never commit.
HL_ACCOUNT_ADDRESS=0xdeadbeef00000000000000000000000000000000
HL_API_SECRET_KEY=0xdeadbeef00000000000000000000000000000000000000000000000000000000

# --- Telegram alerts ---
# Real values: create a bot via @BotFather, send it a message, then fetch
# chat_id from https://api.telegram.org/bot<token>/getUpdates
# Dummy values still let the engine run; you'll see "telegram 4xx" warn logs
# every time an alert fires.
TG_BOT_TOKEN=fake
TG_CHAT_ID=fake
